#pragma once

#include "{{ node.name | kebab }}.hh"

namespace ast {
{% for member in node.members %}
    {% if member.r_acc %}
    inline {{ member.type.r_type }} {{ node.name }}::get_{{ member.name }}() const {
        {% if member.type.need_deref() %}
        return *{{ member.name }}_;
        {% else %}
        return {{ member.name }}_;
        {% endif %}
    }

    {% endif %}
    {% if member.w_acc %}
    inline {{ member.type.w_type }} {{ node.name }}::get_{{ member.name }}() {
        {% if member.type.need_deref() %}
        return *{{ member.name }}_;
        {% else %}
        return {{ member.name }}_;
        {% endif %}
    }

    {% endif %}
    {% if member.W_acc %}
    inline void {{ node.name }}::set_{{ member.name }}({{ member.type.W_type }} {{ member.name }}) {
        {{ member.name }}_ = {{ member.name }};
    }

    {% endif %}
{% endfor %}
    inline void {{ node.name }}::accept(ConstVisitor& visitor) const {
        visitor(*this);
    }

    inline void {{ node.name }}::accept(InvasiveVisitor& visitor) {
        visitor(*this);
    }
} // namespace ast
